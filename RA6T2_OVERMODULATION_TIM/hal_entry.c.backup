//            channel_0_gtcnt_value = R_GPT7->GTCNT;
//            channel_1_gtcnt_value = R_GPT8->GTCNT;
//            channel_2_gtcnt_value = R_GPT9->GTCNT;
//            APP_PRINT("GTCCRA:%ld\r\n", gtccra_value);
//            APP_PRINT("\r\nGTCCRC:%ld\r\n", gtccrc_value);
//            APP_PRINT("\r\nCh0 GTCNT:%ld\r\n", channel_0_gtcnt_value);
//            APP_PRINT("\r\nCh1 GTCNT:%ld\r\n", channel_1_gtcnt_value);
//            APP_PRINT("\r\nCh2 GTCNT:%ld\r\n", channel_2_gtcnt_value);
//            APP_PRINT("GTPR:%ld\r\n", gtpr_value);

            if(PWM_FREQ_SELECTION_MAX == temp_pwm_frequency_selection)
            {
                R_GPT7->GTPDBR = pwm_timer_cycle[pwm_frequency_selection];
            }
            else
            {
                R_GPT7->GTPDBR = pwm_timer_cycle[temp_pwm_frequency_selection];
            }
//            R_GPT7->GTPDBR = pwm_timer_cycle[pwm_frequency_selection];
            request_pwm_frequency_change_in_trough_section = false;
            update_gtccrd_after_pwm_frequency_changed = true;
        }
#elif UPDATE_GTPDBR_IN_WHICH_SECTION == UP_COUNTING_CREST_SECTION

#endif
   }
}

void external_irq_callback(external_irq_callback_args_t *p_args)
{
    if(p_args->channel == PD12_IRQ12_B_HU_2_CHANNEL)
    {
        external_irq_trigger = true;
    }
}

/*******************************************************************************************************************//**
 * This function is called at various points during the startup process.  This implementation uses the event that is
 * called right before main() to set up the pins.
 *
 * @param[in]  event    Where at in the start up process the code is currently at
 **********************************************************************************************************************/
void R_BSP_WarmStart(bsp_warm_start_event_t event)
{
    if (BSP_WARM_START_RESET == event)
    {
#if BSP_FEATURE_FLASH_LP_VERSION != 0

        /* Enable reading from data flash. */
        R_FACI_LP->DFLCTL = 1U;

        /* Would normally have to wait tDSTOP(6us) for data flash recovery. Placing the enable here, before clock and
         * C runtime initialization, should negate the need for a delay since the initialization will typically take more than 6us. */
#endif
    }

    if (BSP_WARM_START_POST_C == event)
    {
        /* C runtime environment and system clocks are setup. */

        /* Configure pins. */
        R_IOPORT_Open (&g_ioport_ctrl, g_ioport.p_cfg);
    }
}

