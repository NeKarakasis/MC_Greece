//            if(three_phase_gtccrd_target[pwm_frequency_selection].u_phase_gtccrd > gtpr_value)
//            {
//                uint8_t pwm_frequency = (PWM_10KHZ == pwm_frequency_selection)?PWM_20KHZ:PWM_10KHZ;
//                R_GPT7->GTCCR[GPT_THREE_PHASE_PRV_GTCCRD] = three_phase_gtccrd_target[pwm_frequency].u_phase_gtccrd;
//                R_GPT8->GTCCR[GPT_THREE_PHASE_PRV_GTCCRD] = three_phase_gtccrd_target[pwm_frequency].v_phase_gtccrd;
//                R_GPT9->GTCCR[GPT_THREE_PHASE_PRV_GTCCRD] = three_phase_gtccrd_target[pwm_frequency].w_phase_gtccrd;
////                update_gtccrd_after_pwm_frequency_changed_next_cyle = true;
//            }
//            else
//            {
//
//                R_GPT7->GTCCR[GPT_THREE_PHASE_PRV_GTCCRD] = three_phase_gtccrd_target[pwm_frequency_selection].u_phase_gtccrd;
//                R_GPT8->GTCCR[GPT_THREE_PHASE_PRV_GTCCRD] = three_phase_gtccrd_target[pwm_frequency_selection].v_phase_gtccrd;
//                R_GPT9->GTCCR[GPT_THREE_PHASE_PRV_GTCCRD] = three_phase_gtccrd_target[pwm_frequency_selection].w_phase_gtccrd;
//                update_gtccrd_after_pwm_frequency_changed = false;
//            }
#endif

#if DEBUG_OUTPUT_PD00_ENABLE
            R_IOPORT_PinWrite(&g_ioport_ctrl, BSP_IO_PORT_13_PIN_00, BSP_IO_LEVEL_LOW);
