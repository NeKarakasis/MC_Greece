#include "hal_data.h"
#include "common_utils.h"

FSP_CPP_HEADER
void R_BSP_WarmStart(bsp_warm_start_event_t event);
FSP_CPP_FOOTER

static fsp_err_t gpt_complementary_pwm_mode_3_init (void);

volatile bool external_irq_trigger = false;
volatile bool request_pwm_frequency_change_in_crest_section = false;
volatile bool request_pwm_frequency_change_in_trough_section = false;
volatile bool update_gtccrd_after_pwm_frequency_changed = false;
//volatile bool update_gtccrd_after_pwm_frequency_changed_next_cyle = false;

volatile uint8_t pwm_frequency_selection = PWM_10KHZ;
volatile uint8_t temp_pwm_frequency_selection = PWM_FREQ_SELECTION_MAX;
volatile three_phase_gtccrd_value_t three_phase_gtccrd_target[PWM_FREQ_SELECTION_MAX];
volatile uint32_t pwm_timer_cycle[PWM_FREQ_SELECTION_MAX];

static volatile uint32_t gtpr_value = 0;
//static volatile uint32_t gtccra_value = 0;
//static volatile uint32_t gtccrc_value = 0;
//static volatile uint32_t channel_0_gtcnt_value = 0;
//static volatile uint32_t channel_1_gtcnt_value = 0;
//static volatile uint32_t channel_2_gtcnt_value = 0;
/*******************************************************************************************************************//**
 * main() is generated by the RA Configuration editor and is used to generate threads if an RTOS is used.  This function
 * is called by main() when no RTOS is used.
 **********************************************************************************************************************/
void hal_entry(void)
{
    /* TODO: add your own code here */
    fsp_err_t err = FSP_SUCCESS;
    fsp_pack_version_t version =   { RESET_VALUE };
    bsp_io_level_t input_level;
    uint8_t input_debounce_count = 0;

    /* version get API for FLEX pack information */
    R_FSP_VersionGet (&version);

    APP_PRINT(BANNER_INFO, EP_VERSION, version.version_id_b.major, version.version_id_b.minor, version.version_id_b.patch);

    three_phase_gtccrd_target[PWM_10KHZ].u_phase_gtccrd = 5000;
    three_phase_gtccrd_target[PWM_10KHZ].v_phase_gtccrd = 5000;
    three_phase_gtccrd_target[PWM_10KHZ].w_phase_gtccrd = 5000;

    three_phase_gtccrd_target[PWM_20KHZ].u_phase_gtccrd = 1500;
    three_phase_gtccrd_target[PWM_20KHZ].v_phase_gtccrd = 1500;
    three_phase_gtccrd_target[PWM_20KHZ].w_phase_gtccrd = 1500;

    pwm_timer_cycle[PWM_10KHZ] = PWM_10KHZ_TIMER_CYCLE_SETTING;
    pwm_timer_cycle[PWM_20KHZ] = PWM_20KHZ_TIMER_CYCLE_SETTING;

    err = R_ICU_ExternalIrqOpen(&g_external_irq_PD12_ctrl, &g_external_irq_PD12_cfg);
    assert(err == FSP_SUCCESS);

    err = R_ICU_ExternalIrqEnable(&g_external_irq_PD12_ctrl);
    assert(err == FSP_SUCCESS);

    /* Complementary PWM mode Setting */
    err = gpt_complementary_pwm_mode_3_init();
    assert(err == FSP_SUCCESS);

    while(1)
    {
        if(external_irq_trigger)
        {
            do
            {
                R_BSP_SoftwareDelay(1, BSP_DELAY_UNITS_MILLISECONDS);

                R_IOPORT_PinRead(&g_ioport_ctrl, PD12_IRQ12_B_HU_2, &input_level);
                input_debounce_count++;
                if(input_debounce_count >= 100)
                {
#if UPDATE_GTPDBR_IN_WHICH_SECTION == DOWN_COUNTING_TROUGH_SECTION
                    gtpr_value = R_GPT7->GTPR;

#if 1
                    uint8_t pwm_frequency = (PWM_10KHZ == pwm_frequency_selection) ? PWM_20KHZ:PWM_10KHZ;
                    if(three_phase_gtccrd_target[pwm_frequency].u_phase_gtccrd < gtpr_value)
                    {
                        pwm_frequency_selection = pwm_frequency;
                        temp_pwm_frequency_selection = PWM_FREQ_SELECTION_MAX;
                    }
                    else
                    {
                        temp_pwm_frequency_selection = pwm_frequency;
                    }
#else
                    if(PWM_10KHZ == pwm_frequency_selection)
                    {
                        pwm_frequency_selection = PWM_20KHZ;
                    }
                    else
                    {
                        pwm_frequency_selection = PWM_10KHZ;
                    }
#endif

                    update_gtccrd_after_pwm_frequency_changed = false;
                    request_pwm_frequency_change_in_trough_section = true;
#elif UPDATE_GTPDBR_IN_WHICH_SECTION == UP_COUNTING_CREST_SECTION

#endif
                    break;
                }
            }while(BSP_IO_LEVEL_LOW == input_level);

            input_debounce_count = 0;
            external_irq_trigger = false;
        }
    }
}


static fsp_err_t gpt_complementary_pwm_mode_3_init (void)
{
    fsp_err_t err = FSP_SUCCESS;

    /* Initializes the module. */
    err = R_GPT_THREE_PHASE_Open(&g_three_phase0_ctrl, &g_three_phase0_cfg);

    /* Handle any errors. This function should be defined by the user. */
    if(FSP_SUCCESS != err)
    {
        return err;
    }

    R_GPT7->GTCR_b.MD = COMPLEMENTARY_PWM_MODE_3;//0x0C;//0x0D;//0x0E;//14;
    R_GPT8->GTCR_b.MD = COMPLEMENTARY_PWM_MODE_3;//0x0C;//0x0D;//0x0E;//14;
    R_GPT9->GTCR_b.MD = COMPLEMENTARY_PWM_MODE_3;//0x0C;//0x0D;//0x0E;//14;

    /*
     * GTBER: General PWM Timer Buffer Enable
     * - GTCCR Buffer Operation
     * - GTPR Buffer Operation
     * - GTADTRA/GTADTRB Buffer Operation
     * - GTDVU/GTDVD Buffer
     */
    R_GPT7->GTBER_b.BD0 = 0; //GTCCCR Buffer operation is enabled
    R_GPT7->GTBER_b.BD1 = 0; //GTPR Buffer operation is enabled
    R_GPT7->GTBER_b.BD2 = 1; //GTADTRA/GTADTRB Buffer operation is enabled
    R_GPT7->GTBER_b.BD3 = 0; //GTDUV/GTDVD Buffer operation is enabled
    R_GPT7->GTBER_b.DBRTECA = 0;
    R_GPT7->GTBER_b.DBRTECB = 0;
    R_GPT7->GTBER_b.CCRA = 1;//Single buffer operation (GTCCRA <=> GTCCRC)
    R_GPT7->GTBER_b.CCRB = 1;//Single buffer operation (GTCCRB <=> GTCCRE)
    R_GPT7->GTBER_b.PR = 1;  //Single buffer operation (GTPBR <=> GTPR), the setting of this bit does not matter for complementary PWM mode 3, 4
    R_GPT7->GTBER_b.CCRSWT = 0; //No force write
    R_GPT7->GTBER_b.ADTTA = 0;
    R_GPT7->GTBER_b.ADTDA = 0;
    R_GPT7->GTBER_b.ADTTB = 0;
    R_GPT7->GTBER_b.ADTDB = 0;

    R_GPT8->GTBER_b.BD0 = 0; //GTCCCR Buffer operation is enabled
    R_GPT8->GTBER_b.BD1 = 0; //GTPR Buffer operation is enabled
    R_GPT8->GTBER_b.BD2 = 1; //GTADTRA/GTADTRB Buffer operation is enabled
    R_GPT8->GTBER_b.BD3 = 0; //GTDUV/GTDVD Buffer operation is enabled
    R_GPT8->GTBER_b.DBRTECA = 0;
    R_GPT8->GTBER_b.DBRTECB = 0;
    R_GPT8->GTBER_b.CCRA = 1;//Single buffer operation (GTCCRA <=> GTCCRC)
    R_GPT8->GTBER_b.CCRB = 1;//Single buffer operation (GTCCRB <=> GTCCRE)
    R_GPT8->GTBER_b.PR = 1;  //Single buffer operation (GTPBR <=> GTPR)
    R_GPT8->GTBER_b.CCRSWT = 0; //No force write
    R_GPT8->GTBER_b.ADTTA = 0;
    R_GPT8->GTBER_b.ADTDA = 0;
    R_GPT8->GTBER_b.ADTTB = 0;
    R_GPT8->GTBER_b.ADTDB = 0;

    R_GPT9->GTBER_b.BD0 = 0; //GTCCCR Buffer operation is enabled
    R_GPT9->GTBER_b.BD1 = 0; //GTPR Buffer operation is enabled
    R_GPT9->GTBER_b.BD2 = 1; //GTADTRA/GTADTRB Buffer operation is enabled
    R_GPT9->GTBER_b.BD3 = 0; //GTDUV/GTDVD Buffer operation is enabled
    R_GPT9->GTBER_b.DBRTECA = 0;
    R_GPT9->GTBER_b.DBRTECB = 0;
    R_GPT9->GTBER_b.CCRA = 1;//Single buffer operation (GTCCRA <=> GTCCRC)
    R_GPT9->GTBER_b.CCRB = 1;//Single buffer operation (GTCCRB <=> GTCCRE)
    R_GPT9->GTBER_b.PR = 1;  //Single buffer operation (GTPBR <=> GTPR)
    R_GPT9->GTBER_b.CCRSWT = 0; //No force write
    R_GPT9->GTBER_b.ADTTA = 0;
    R_GPT9->GTBER_b.ADTDA = 0;
    R_GPT9->GTBER_b.ADTTB = 0;
    R_GPT9->GTBER_b.ADTDB = 0;

    R_GPT7->GTPR = pwm_timer_cycle[pwm_frequency_selection];
    R_GPT8->GTPR = pwm_timer_cycle[pwm_frequency_selection];
    R_GPT9->GTPR = pwm_timer_cycle[pwm_frequency_selection];
    R_GPT7->GTPBR = pwm_timer_cycle[pwm_frequency_selection];
    R_GPT8->GTPBR = pwm_timer_cycle[pwm_frequency_selection];
    R_GPT9->GTPBR = pwm_timer_cycle[pwm_frequency_selection];
    R_GPT7->GTPDBR = pwm_timer_cycle[pwm_frequency_selection];
    R_GPT8->GTPDBR = pwm_timer_cycle[pwm_frequency_selection];
    R_GPT9->GTPDBR = pwm_timer_cycle[pwm_frequency_selection];

    /*
     * GTIOR : General PWM Timer I/O Control Register
     * - GTIOA/B = 0x09
     *  - Initial output is Low (Active level is High),
     *  - High output in up count compare match
     *  - Low output in down count compare match
     * - GTIOB/B = 0x06
     *  - Initial output is Low (Active level is High),
     *  - Low output in up count compare match
     *  - High output in down count compare match
     * - GTIOA/B = 0x19
     *  - Initial output is High (Active level is Low),
     *  - High output in up count compare match
     *  - Low output in down count compare match
     * - GTIOB/B = 0x16
     *  - Initial output is High (Active level is Low),
     *  - Low output in up count compare match
     *  - High output in down count compare match
     */
    R_GPT7->GTIOR_b.GTIOA = 0x06;
    R_GPT8->GTIOR_b.GTIOA = 0x06;
    R_GPT9->GTIOR_b.GTIOA = 0x06;
    R_GPT7->GTIOR_b.GTIOB = 0x09;
    R_GPT8->GTIOR_b.GTIOB = 0x09;
    R_GPT9->GTIOR_b.GTIOB = 0x09;

    /*PSYE: PWM Synchronous output Enable:
     * Enable GTCPPOT7 output */
    R_GPT7->GTIOR_b.PSYE = 1;

#if 1
    /*
     * GTBER2: General PWM Timer Buffer Enable 2
     * - CP3DB=0 : Disable double buffer function in complementary PWM mode 3, 4
     * - OLTTA: GTIOCnA Output Level Buffer Transfer Timing Select
     * - OLTTB: GTIOCnB Output Level Buffer Transfer Timing Select
     */
    R_GPT7->GTBER2_b.CP3DB = 0;
    R_GPT7->GTBER2_b.OLTTA = 3; //complementary PWM mode: Transfer at both crest and trough
    R_GPT7->GTBER2_b.OLTTB = 3; //complementary PWM mode: Transfer at both crest and trough

    R_GPT8->GTBER2_b.CP3DB = 0;
    R_GPT8->GTBER2_b.OLTTA = 3; //complementary PWM mode: Transfer at both crest and trough
    R_GPT8->GTBER2_b.OLTTB = 3; //complementary PWM mode: Transfer at both crest and trough

    R_GPT9->GTBER2_b.CP3DB = 0;
    R_GPT9->GTBER2_b.OLTTA = 3; //complementary PWM mode: Transfer at both crest and trough
    R_GPT9->GTBER2_b.OLTTB = 3; //complementary PWM mode: Transfer at both crest and trough
#else
    // GTBER2.CP3DB, This bit is only available in GPT324 to GPT329.
    R_GPT7->GTBER2_b.CP3DB = 0;//0x06;//0x0E;//0x05;
    R_GPT8->GTBER2_b.CP3DB = 0;//0x06;//0x0E;//0x05;
    R_GPT9->GTBER2_b.CP3DB = 0;//0x06;//0x0E;//0x05;
#endif

    R_GPT7->GTCCR[GPT_THREE_PHASE_PRV_GTCCRD] = three_phase_gtccrd_target[pwm_frequency_selection].u_phase_gtccrd;
    R_GPT8->GTCCR[GPT_THREE_PHASE_PRV_GTCCRD] = three_phase_gtccrd_target[pwm_frequency_selection].v_phase_gtccrd;
    R_GPT9->GTCCR[GPT_THREE_PHASE_PRV_GTCCRD] = three_phase_gtccrd_target[pwm_frequency_selection].w_phase_gtccrd;

    /* Start the timer. */
    err = R_GPT_THREE_PHASE_Start(&g_three_phase0_ctrl);
    if(FSP_SUCCESS != err)
    {
        return err;
    }

    return FSP_SUCCESS;
}

//uint8_t isExecuted = false; // Flag to track if the block has been executed
