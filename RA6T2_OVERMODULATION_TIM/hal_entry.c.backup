{
    /* TODO: add your own code here */
    if(p_args->event == TIMER_EVENT_CREST)
    {
#if UPDATE_GTPDBR_IN_WHICH_SECTION == DOWN_COUNTING_TROUGH_SECTION
        if(update_gtccrd_after_pwm_frequency_changed)
        {
#if 0
