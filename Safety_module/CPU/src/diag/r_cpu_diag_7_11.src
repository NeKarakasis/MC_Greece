.INCLUDE r_cpu_diag_config.inc
.INCLUDE r_cpu_diag.inc

.IF RX_CPU_TYPE >= CPU_RXv2

.GLB    _R_CPU_Diag7_11
.SECTION RX_DSW_P, CODE

;; EXTB diagnostic macro ;;
;; Diagnostic EXTB
_DiagEXTB .MACRO
    ;; Write to EXTB
    MVTC R7, EXTB

    ;; Read from EXTB
    MVFC EXTB, R8

    ;; Compare read EXTB with written data
    CMP R7, R8
    BNE.W ErrEnd

.ENDM

_R_CPU_Diag7_11:

    ;; ==== Save EXTB, R6-R13, PSW. _SaveReg Rns, PSW, FPSW ==== ;;
    _SaveRegs 1, 1, 0
    MVFC EXTB, R9

    ;; ======== 27 Detecting "0" fixed fault for EXTB ======== ;;
    ; Set EXTB write data to R7
    MOV.L #0FFFFFFFFH, R7

    ;; Diagnostic EXTB
    _DiagEXTB

    ;; ======== 28 Detecting "1" fixed fault for EXTB ======== ;;
    ; Set EXTB write data to R7
    MOV.L #00000000H, R7

    ;; Diagnostic EXTB
    _DiagEXTB

    ;; ======== 29 Detecting coupling fault for EXTB between any two bits ======== ;;
    ;; ==== Nearest neighbor coupling ==== ;;
    ; Set H'55555555 pattern to R7
    MOV.L #55555555H, R7

    ;; Diagnostic EXTB applying H'55555555 pattern
    _DiagEXTB

    ;; ==== Next nearest neighbor coupling ==== ;;
    ; Set H'33333333 pattern to R7
    MOV.L #33333333H, R7

    ;; Diagnostic EXTB applying H'33333333 pattern
    _DiagEXTB

    ;; ==== 4-fold neighbor coupling ==== ;;
    ; Set H'0F0F0F0F pattern to R7
    MOV.L #0F0F0F0FH, R7

    ;; Diagnostic EXTB applying H'0F0F0F0F pattern
    _DiagEXTB

    ;; ==== 8-fold neighbor coupling ==== ;;
    ; Set H'00FF00FF pattern to R7
    MOV.L #00FF00FFH, R7

    ;; Diagnostic EXTB applying H'00FF00FF pattern
    _DiagEXTB

    ;; ==== 16-fold neighbor coupling ==== ;;
    ; Set H'0000FFFF pattern to R7
    MOV.L #0000FFFFH, R7

    ;; Diagnostic EXTB applying H'0000FFFF pattern
    _DiagEXTB

    ;; ==== Finalizing operation ==== ;;
NoErrEnd:
    MOV.L #00000000H, R15  ; No error detection flag is 0x00000000
    BRA.S DiagEnd

ErrEnd:
    MOV.L #00000001H, R15  ; Error detection flag is 0x00000001

DiagEnd:
    ;; Pseudo expectation value
    MOV.L #00000000H, R14
    _FinOpe

    ;; ==== Restore EXTB, R6-R13, PSW. _RestReg Rns, PSW, FPSW ==== ;;
    MVTC R9, EXTB
    _RestRegs 1, 1, 0

    RTS

.ENDIF  ; .IF RX_CPU_TYPE >= CPU_RXv2

.END
